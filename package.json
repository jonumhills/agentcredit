{
  "name": "agentcredit",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "contracts",
    "backend",
    "frontend",
    "agents"
  ],
  "scripts": {
    "contracts:compile": "npm run compile --workspace=contracts",
    "contracts:test": "npm run test --workspace=contracts",
    "contracts:deploy": "npm run deploy:xlayer --workspace=contracts",
    "backend:dev": "npm run dev --workspace=backend",
    "frontend:dev": "npm run dev --workspace=frontend",
    "agents:lender": "npm run lender --workspace=agents",
    "agents:borrower": "npm run borrower --workspace=agents",
    "install:all": "npm install --workspaces"
  },
  "description": "AgentCredit — Agent-native lending platform on X Layer",
  "keywords": [
    "defi",
    "agents",
    "xlayer",
    "lending",
    "okx",
    "hackathon"
  ]
}
